               27 => 16#0000#,
               28 => 16#0000#,
               29 => 16#2900_2900#,
               30 => 16#0000#),
            ELR_EL2              => 16#2985_7000#,
            VTTBR_Address        => 16#0020_0000#,
            Default_Cacheability => False,
            Trap_WFI_Instruction => False,
            Trap_WFE_Instruction => False,
            Interrupt_Support    => True),
         1 =>
           (CPU_ID               => 0,
            GPRs                 => (
               0 => 16#0000#,
               1 => 16#1111#,
               2 => 16#2222#,
               3 => 16#0000#,
               4 => 16#0000#,
