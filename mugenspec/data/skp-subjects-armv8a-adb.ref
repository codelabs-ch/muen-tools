               15 => 16#0000#,
               16 => 16#0000#,
               17 => 16#0000#,
               18 => 16#0000#,
               19 => 16#0000#,
               20 => 16#2020#,
               21 => 16#0000#,
               22 => 16#0000#,
               23 => 16#0000#,
               24 => 16#0000#,
               25 => 16#0000#,
